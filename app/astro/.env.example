# Copy to `.env` for local `astro dev start`. Astro loads `.env` automatically.
# These let base.py / the ingestion operator resolve config locally.

# Fake GCP project ids (replace with your real ones if deploying)
GCP_PROJECT_DEV=REPLACE-ME-music-stream-dev
GCP_PROJECT_PRD=REPLACE-ME-music-stream-prd
GCP_REGION=europe-west1

# MongoDB seeded by docker-compose.yml. From inside the Astro containers the
# host is reachable via host.docker.internal.
MONGO_URI=mongodb://music_app:music_pw@host.docker.internal:27017/music_streaming?authSource=admin
